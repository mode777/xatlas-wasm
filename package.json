{
  "name": "xatlas-wasm",
  "version": "0.1.2",
  "description": "xatlas UV atlas generation library compiled to WebAssembly",
  "type": "module",
  "main": "lib/xatlas.mjs",
  "module": "lib/xatlas.mjs",
  "types": "lib/xatlas.d.ts",
  "exports": {
    ".": {
      "import": "./lib/xatlas.mjs",
      "types": "./lib/xatlas.d.ts"
    }
  },
  "files": [
    "dist/",
    "lib/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "configure": "emcmake cmake -B build -DCMAKE_BUILD_TYPE=Release",
    "build": "cmake --build build",
    "clean": "rimraf build dist",
    "example": "npx serve . -l 3000 --no-clipboard",
    "test": "node test/test.mjs"
  },
  "keywords": [
    "xatlas",
    "uv",
    "atlas",
    "mesh",
    "wasm",
    "webassembly",
    "texture",
    "unwrap"
  ],
  "license": "MIT",
  "author": "alexander.klingenbeck@gmx.de",
  "repository": {
    "type": "git",
    "url": "https://github.com/mode777/xatlas-wasm.git"
  },
  "homepage": "https://github.com/mode777/xatlas-wasm#readme",
  "bugs": {
    "url": "https://github.com/mode777/xatlas-wasm/issues"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
